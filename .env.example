# --- Telegram-бот для ПУБЛИКАЦИИ (от @BotFather) ---
# 1. Напишите @BotFather → /newbot → получите токен.
# 2. Добавьте этого бота АДМИНОМ в ваш канал-приёмник (право "Post messages").
BOT_TOKEN=123456:ABC-DEF...

# Ваш канал-приёмник: @username (если публичный) или числовой id вида -100...
DESTINATION_CHANNEL=@my_loko_channel

# Каналы-ИСТОЧНИКИ (все публичные, проверено). Менять/добавлять можно свободно.
SOURCE_CHANNELS=karpinside,offsider,Anario_13,punkinside,zabuxaem,registaJournalista,alexeevkv,ilyevserg

# Ключ Gemini API — бесплатно на aistudio.google.com
GEMINI_API_KEY=AIzaSy...

# Необязательно
POLL_INTERVAL=120          # секунд между опросами источников
ADD_SOURCE_LINK=true       # добавлять "Источник: ..." в конец поста
